&lt;pre tabindex="0" class="chroma">&lt;code class="language-bash" data-lang="bash">&lt;span class="line">&lt;span class="cl">curl -F &lt;span class="nv">file&lt;/span>&lt;span class="o">=&lt;/span>@starship.toml https://0x0.st
